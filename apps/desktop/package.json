{
  "name": "opencrab-desktop",
  "version": "1.0.7",
  "description": "OpenCrab Desktop Application",
  "author": "OpenCrab",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:web": "npm --prefix ../web run build",
    "prepare:runtime": "node scripts/pack-runtime-archives.js",
    "predist:win": "npm run build:web && npm run prepare:runtime",
    "predist:mac": "npm run build:web && npm run prepare:runtime",
    "prepack": "npm run build:web && npm run prepare:runtime",
    "pack": "electron-builder --dir -p never",
    "dist:win": "electron-builder --win nsis -p never",
    "dist:mac": "electron-builder --mac dmg zip -p never",
    "build": "npm run dist:win"
  },
  "build": {
    "productName": "OpenCrab",
    "appId": "com.opencrab.desktop",
    "compression": "store",
    "win": {
      "target": "nsis",
      "icon": "../../logo.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "include": "installer.nsh"
    },
    "extraResources": [
      {
        "from": "runtime-archives/venv.tar.gz",
        "to": "runtime-archives/venv.tar.gz"
      },
      {
        "from": "../../opencrab",
        "to": "opencrab",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc", "!**/*.pyo"]
      },
      {
        "from": "../api",
        "to": "apps/api",
        "filter": ["**/*", "!**/__pycache__/**", "!**/*.pyc", "!**/*.pyo"]
      },
      {
        "from": "../web/out",
        "to": "apps/web/out",
        "filter": ["**/*"]
      },
      {
        "from": "../../scripts",
        "to": "scripts",
        "filter": ["**/*"]
      },
      {
        "from": "../../skills",
        "to": "skills",
        "filter": ["**/*"]
      },
      {
        "from": "../../docker-compose.yml",
        "to": "docker-compose.yml"
      },
      {
        "from": "../../.env.example",
        "to": ".env"
      }
    ]
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
